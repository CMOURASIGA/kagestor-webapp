federações e empresas), apoiando a gestão das negociações coletivas em nível nacional.</p>","size":null,"priority":3,"deadline":null,"reporter":{"type":"internal","value":2},"created_at":"2025-06-13T17:53:47Z","revision":22,"last_modified":"2025-07-28T17:38:36Z","in_current_position_since":"2025-06-16T13:02:53Z","first_request_time":"2025-06-16T13:02:45Z","first_start_time":"2025-06-16T13:02:53Z","first_end_time":null,"last_request_time":"2025-06-16T13:02:45Z","last_start_time":"2025-06-16T13:02:53Z","last_end_time":null,"block_reason":null,"child_card_stats":{"child_card_size_sum":1,"finished_bottom_child_card_size_sum":0,"unfinished_bottom_child_card_size_sum":1,"has_unfinished_child_cards":true,"last_unfinished_child_card_deadline":null},"custom_fields":[{"field_id":26,"value":"# O que?<br>Evolução e melhorias no sistema SNCC, incluindo novos recursos de visualização, comparativo de negociações, melhorias de performance, usabilidade e exportação de dados.<div><br># Por que?<br>Atender às necessidades dos usuários (sindicatos, federações e empresas), melhorando a experiência, a performance e a capacidade de análise das informações trabalhistas. Também garantir maior agilidade e qualidade nas consultas e registros de negociações coletivas.</div><div><br># Onde?<br>\tNo ambiente da CNC (Azure e infraestrutura cloud associada), com deploy nas instâncias de homologação e produção do SNCC.</div><div><br># Quando?<br>Projeto em andamento, com fases previstas de desenvolvimento, homologação interna, homologação do cliente e implantação em produção, dentro do cronograma acordado com o time de TI e área de negócios.</div><div><br># Quem?<br>Time de desenvolvimento da CNC</div><div><br># Como?<br>Através de sprints de desenvolvimento, validações contínuas com o PO, homologação com usuários finais e implantação seguindo boas práticas de versionamento e controle de mudança.</div><div><br># Quanto?<br>Trata-se de uma atividade preventiva sem custo adicional direto, executada por equipe de profissional alocados como parte das rotinas de segurança e conformidade.<br><br>        </div>"}],"stickers":[],"tag_ids":[],"co_owner_ids":[20],"watcher_ids":[],"attachments":[],"cover_image":null,"checked_column_checklist_items":[],"annotations":[],"initiative_details":{"has_manually_set_start_time":0,"has_manually_set_end_time":0,"planned_start_date_sync_type":null,"planned_start_date_sync_monday_is_working_day":1,"planned_start_date_sync_tuesday_is_working_day":1,"planned_start_date_sync_wednesday_is_working_day":1,"planned_start_date_sync_thursday_is_working_day":1,"planned_start_date_sync_friday_is_working_day":1,"planned_start_date_sync_saturday_is_working_day":1,"planned_start_date_sync_sunday_is_working_day":1,"planned_start_date":null,"planned_end_date_sync_type":null,"planned_end_date":null,"actual_start_time":"2025-06-16T13:02:53Z","actual_end_time":null,"track":null},"outcomes":[],"links_from_outcomes":[],"outcome_current_values":[],"finished_subtask_count":3,"unfinished_subtask_count":2,"comment_count":0,"current_cycle_time":3654862,"lead_time_per_column":[{"column_id":6,"lead_time":241738},{"column_id":7,"lead_time":8},{"column_id":8,"lead_time":3654854}],"current_block_time":0,"transitions":[{"board_id":1,"workflow_id":2,"section":1,"column_id":6,"lane_id":82,"start":"2025-06-13T17:53:47Z","end":"2025-06-16T13:02:45Z"},{"board_id":1,"workflow_id":2,"section":2,"column_id":7,"lane_id":82,"start":"2025-06-16T13:02:45Z","end":"2025-06-16T13:02:53Z"},{"board_id":1,"workflow_id":2,"section":3,"column_id":8,"lane_id":82,"start":"2025-06-16T13:02:53Z","end":null}],"block_times":[],"current_logged_time":0,"logged_times":[],"logged_times_for_child_cards":[],"subtasks":[{"subtask_id":1424,"description":"<p>Definição e Planejamento</p>","owner_user_id":null,"finished_at":"2025-06-16T13:02:35Z","deadline":null,"position":0,"attachments":[]},{"subtask_id":1425,"description":"<p>Desenvolvimento Técnico</p>","owner_user_id":null,"finished_at":"2025-06-16T13:02:39Z","deadline":null,"position":1,"attachments":[]},{"subtask_id":1426,"description":"<p>Homologação Interna e Testes</p>","owner_user_id":null,"finished_at":"2025-07-28T17:38:36Z","deadline":null,"position":2,"attachments":[]},{"subtask_id":1427,"description":"<p>Homologação com o Cliente / Stakeholders</p>","owner_user_id":null,"finished_at":null,"deadline":null,"position":3,"attachments":[]},{"subtask_id":1428,"description":"<p>Implantação em Produção</p>","owner_user_id":null,"finished_at":null,"deadline":null,"position":4,"attachments":[]}],"linked_cards":[{"card_id":1429,"link_type":"child"}]},{"card_id":1148,"custom_id":null,"board_id":1,"workflow_id":2,"title":"Catalogação automatizada de processos sindicais","owner_user_id":2,"type_id":7,"color":"607d8b","is_blocked":0,"section":3,"column_id":8,"lane_id":2,"position":4,"description":"<p>Automatizar as atividades de cadastro dos processos sindicais em papel no sistema Interfy, utilizando o LiaDOX, com o objetivo de acelerar a catalogação e o envio desses documentos para dentro do Interfy.</p>","size":null,"priority":3,"deadline":"2025-09-20T12:00:00Z","reporter":{"type":"internal","value":2},"created_at":"2025-05-01T12:31:50Z","revision":29,"last_modified":"2025-07-18T20:15:29Z","in_current_position_since":"2025-05-09T16:45:52Z","first_request_time":"2025-05-01T12:33:48Z","first_start_time":"2025-05-09T16:45:52Z","first_end_time":null,"last_request_time":"2025-05-01T12:33:48Z","last_start_time":"2025-05-09T16:45:52Z","last_end_time":null,"block_reason":null,"child_card_stats":{"child_card_size_sum":3,"finished_bottom_child_card_size_sum":1,"unfinished_bottom_child_card_size_sum":2,"has_unfinished_child_cards":true,"last_unfinished_child_card_deadline":null},"custom_fields":[{"field_id":26,"value":"# O que?<div>Será realizada uma Prova de Conceito (PoC) da plataforma LiaDox para automatizar o cadastro dos processos sindicais físicos no sistema Interfy, atualmente realizado manualmente. A solução utiliza inteligência artificial para classificar documentos e extrair metadados, promovendo o envio automático das informações para o GED da CNC.</div><div><br></div><div># Por que?</div><div>O processo manual de digitalização e cadastro é lento, sujeito a erros e demanda alto esforço operacional de equipes terceirizadas. A proposta visa acelerar a catalogação, reduzir custos com mão de obra, aumentar a acurácia das informações inseridas e melhorar a eficiência geral da Diretoria Jurídica e Sindical (DJS).</div><div><br></div><div># Onde?</div><div>A PoC será conduzida em ambiente controlado, utilizando a estrutura da DJS e o sistema Interfy como destino dos documentos processados. A avaliação ocorrerá com dados reais, manipulados por usuários da própria área.</div><div><br></div><div># Quando?</div><div>A PoC terá duração de três meses, com início após aprovação formal do projeto. Caso seja bem-sucedida, a operação em produção será iniciada conforme cronograma financeiro já definido, com vigência mínima contratual de 12 meses.</div><div><br></div><div># Quem?</div><div>A iniciativa é da Diretoria Jurídica e Sindical da CNC, com apoio da área de TI e participação direta do fornecedor LiaDox, responsável pela execução da PoC e pela integração técnica com o Interfy.</div><div><br></div><div># Como?</div><div>A plataforma LiaDox será configurada com as funcionalidades essenciais para processar documentos físicos dos processos sindicais, extraindo dados e enviando diretamente ao Interfy sem intervenção humana. A PoC avaliará critérios como acurácia da extração, usabilidade da interface e integração com o GED. Há termo de confidencialidade vigente para uso de dados reais.</div><div><br></div><div># Quanto?</div><div>A PoC será executada sem custo para a CNC. Em caso de aprovação:<br>&nbsp;- Mês 1 a 6: R$ 43.000,00/mês (base 100.000 páginas)</div><div>&nbsp;- Mês 7 a 12: R$ 14.900,00/mês (franquia mínima de 5.000 páginas)</div><div>&nbsp;- A partir do 13º mês: R$ 9.650,00/mês (franquia mínima de 5.000 páginas)<br>                <br>        </div>"}],"stickers":[],"tag_ids":[],"co_owner_ids":[],"watcher_ids":[],"attachments":[],"cover_image":null,"checked_column_checklist_items":[],"annotations":[],"initiative_details":{"has_manually_set_start_time":0,"has_manually_set_end_time":0,"planned_start_date_sync_type":null,"planned_start_date_sync_monday_is_working_day":1,"planned_start_date_sync_tuesday_is_working_day":1,"planned_start_date_sync_wednesday_is_working_day":1,"planned_start_date_sync_thursday_is_working_day":1,"planned_start_date_sync_friday_is_working_day":1,"planned_start_date_sync_saturday_is_working_day":1,"planned_start_date_sync_sunday_is_working_day":1,"planned_start_date":"2025-05-02","planned_end_date_sync_type":null,"planned_end_date":"2025-09-20","actual_start_time":"2025-05-09T16:45:52Z","actual_end_time":null,"track":null},"outcomes":[],"links_from_outcomes":[],"outcome_current_values":[],"finished_subtask_count":1,"unfinished_subtask_count":2,"comment_count":0,"current_cycle_time":7630999,"lead_time_per_column":[{"column_id":6,"lead_time":118},{"column_id":7,"lead_time":41},{"column_id":56,"lead_time":706283},{"column_id":8,"lead_time":6924675}],"current_block_time":0,"transitions":[{"board_id":1,"workflow_id":2,"section":1,"column_id":6,"lane_id":82,"start":"2025-05-01T12:31:50Z","end":"2025-05-01T12:33:48Z"},{"board_id":1,"workflow_id":2,"section":2,"column_id":7,"lane_id":82,"start":"2025-05-01T12:33:48Z","end":"2025-05-01T12:33:49Z"},{"board_id":1,"workflow_id":2,"section":3,"column_id":56,"lane_id":2,"start":"2025-05-01T12:33:49Z","end":"2025-05-09T16:45:52Z"},{"board_id":1,"workflow_id":2,"section":3,"column_id":8,"lane_id":2,"start":"2025-05-09T16:45:52Z","end":null}],"block_times":[],"current_logged_time":0,"logged_times":[],"logged_times_for_child_cards":[],"subtasks":[{"subtask_id":1149,"description":"<p>Análise de Viabilidade e Planejamento</p>","owner_user_id":null,"finished_at":"2025-05-01T12:32:25Z",